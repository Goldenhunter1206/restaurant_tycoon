[gd_resource type="Resource" script_class="CompetitionDef" load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/data/competition_def.gd" id="1"]

[resource]
script = ExtResource("1")
id = &"student_slice"
display_name = "Student Slice Showdown"
brief = "Best pizza a student budget can buy — priced under $9."
icon = &"pizza"
product_type = &"pizza"
target_demographics = Array[StringName]([&"students"])
constraints = {
"max_price": 9.0
}
entry_fee = 250.0
reward_cash = 5000.0
reward_reputation = 0.3
reward_trend_days = 5
judging = {
"recipe": 0.6,
"compliance": 0.25,
"novelty": 0.15,
"noise_range": 0.05
}
entry_window_days = 4
judging_day_offset = 2
cadence_days = 42
cadence_offset = 10
